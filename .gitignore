node_modules/
dist/
result/

# Doc-test output: build artifacts are disposable, but keep the rendered .md
# tutorial and the scaffolded example project (doctests/outputs/logos-crypto-utils/).
doctests/outputs/*
!doctests/outputs/*.md
!doctests/outputs/logos-crypto-utils/
# ...but never the build artifacts the doc-test run produces inside the example.
doctests/outputs/logos-crypto-utils/.git/
doctests/outputs/logos-crypto-utils/result
doctests/outputs/logos-crypto-utils/result-*
