node_modules/
dist/
result/

# Doc-test output: build artifacts are disposable, but keep the rendered .md
# tutorials and the scaffolded example projects (doctests/outputs/logos-crypto-utils*/).
doctests/outputs/*
!doctests/outputs/*.md
!doctests/outputs/logos-crypto-utils*/
# ...but never the build artifacts a doc-test run produces inside the examples.
doctests/outputs/logos-crypto-utils*/.git/
doctests/outputs/logos-crypto-utils*/result
doctests/outputs/logos-crypto-utils*/result-*
